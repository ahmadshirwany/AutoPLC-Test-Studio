                  </inputVars>
                  <outputVars>
                    <variable name="ControlSig">
                      <type>
                        <BOOL />
                      </type>
                    </variable>
                  </outputVars>
                </interface>
                <body>
                  <ST>
                    <xhtml xmlns="http://www.w3.org/1999/xhtml">IF feedback&gt;Setpoint+Hyst/2 THEN
	ControlSig:=FALSE;
ELSIF feedback&lt;Setpoint-Hyst/2 THEN
		ControlSig:=TRUE;
END_IF</xhtml>
                  </ST>
                </body>

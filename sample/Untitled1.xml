          <addData>
            <data name="http://www.3s-software.com/plcopenxml/pou" handleUnknown="implementation">
              <pou name="PLC_PRG" pouType="program">
                <interface>
                  <localVars>
                    <variable name="Level_Sim01">
                      <type>
                        <derived name="Level_Sim" />
                      </type>
                    </variable>
                    <variable name="OnOff_cont_01">
                      <type>
                        <derived name="OnOff_Control" />
                      </type>
                    </variable>
                    <variable name="Reset_Trig">
                      <type>
                        <derived name="R_TRIG" />
                      </type>
                    </variable>
                  </localVars>
                </interface>
                <body>
                  <ST>
                    <xhtml xmlns="http://www.w3.org/1999/xhtml">Reset_Trig(CLK := GVL.ResetSystem);
IF Reset_Trig.Q THEN
    // Reset all process vars to initial states
    GVL.Level_PV := 0.0;          // Tank empty
    GVL.Level_Sp := 50.0;         // Default setpoint
    GVL.Hyst := 2.0;              // Default hysteresis
    GVL.PumpCoil := FALSE;        // Pump off
    GVL.DischargeVlve := FALSE;   // Valve closed (no drain)
    GVL.AutoMode := FALSE;        // Start in manual
    GVL.SystemStart := FALSE;     // Stop system
	GVl.ResetSystem := False;
    
    // Optional: Reset internal FB states (if needed)
    // Level_Sim01.Level := 0.0;  // But Level is OUTPUT—handled via PV above
    // For deeper reset, call a custom Reset method in FBs (see Step 3)
END_IF;
IF GVL.SystemStart THEN
	GVL.DischargeVlve := TRUE;
	Level_Sim01(Charge:=GVL.PumpCoil , Discharge:=GVL.DischargeVlve , Level=&gt;GVL.Level_PV );
	IF GVL.AutoMode THEN
		OnOff_cont_01(Feedback:=GVL.Level_PV , Setpoint:=GVL.Level_Sp , Hyst:=GVL.Hyst , ControlSig=&gt;GVL.PumpCoil );
	END_IF
ELSE
    // Safe stop: Turn off actuators, hold level (no sim updates)
    GVL.PumpCoil := FALSE;
    GVL.DischargeVlve := FALSE;  // Assuming you want to close discharge too—adjust if it's a leak sim.
    // Optional: Reset level to 0 or SP on stop? Uncomment if needed.
    // GVL.Level_PV := 0.0;  // Or GVL.Level_Sp;
END_IF;</xhtml>
                  </ST>
                </body>
                <addData>
                  <data name="http://www.3s-software.com/plcopenxml/objectid" handleUnknown="discard">
                    <ObjectId>f8f327a2-0df3-4f5d-a17e-54b0e9f21db0</ObjectId>
                  </data>
                </addData>
              </pou>
            </data>
            <data name="http://www.3s-software.com/plcopenxml/pou" handleUnknown="implementation">
              <pou name="Level_Sim" pouType="functionBlock">
                <interface>
                  <inputVars>
                    <variable name="Charge">
                      <type>
                        <BOOL />
                      </type>
                    </variable>
                    <variable name="Discharge">
                      <type>
                        <BOOL />
                      </type>
                    </variable>
                  </inputVars>
                  <outputVars>
                    <variable name="Level">
                      <type>
                        <REAL />
                      </type>
                    </variable>
                  </outputVars>
                  <localVars>
                    <variable name="Blink_Charge">
                      <type>
                        <derived name="Blink" />
                      </type>
                    </variable>
                    <variable name="Blink_Discharge">
                      <type>
                        <derived name="Blink" />
                      </type>
                    </variable>
                    <variable name="Charge_RE">
                      <type>
                        <derived name="R_trig" />
                      </type>
                    </variable>
                    <variable name="DisCharge_RE">
                      <type>
                        <derived name="R_trig" />
                      </type>
                    </variable>
                  </localVars>
                </interface>
                <body>
                  <ST>
                    <xhtml xmlns="http://www.w3.org/1999/xhtml">// Charging simulator
Blink_Charge(ENABLE:=Charge , TIMELOW:=T#100MS , TIMEHIGH:=T#100MS , OUT=&gt; );
Charge_RE(CLK:= Blink_Charge.OUT, Q=&gt; );
IF Charge_RE.Q THEN
	Level:= Level+0.4;
END_IF
// Discharging simulator
Blink_Discharge(ENABLE:= Discharge , TIMELOW:=T#100MS , TIMEHIGH:=T#100MS , OUT=&gt; );
DisCharge_RE(CLK:=Blink_Discharge.OUT , Q=&gt; );
IF DisCharge_RE.Q THEN
	Level:= Level-0.1;
END_IF
// in this case rate of charging in bigger than discharge
IF Level&lt;0 THEN
	Level:=0;
END_IF
IF  Level &gt; 100 THEN
	Level:=100;
END_IF


</xhtml>
                  </ST>
                </body>
                <addData>
                  <data name="http://www.3s-software.com/plcopenxml/objectid" handleUnknown="discard">
                    <ObjectId>01eff67c-649d-4ca9-bf47-e619b23c5d49</ObjectId>
                  </data>
                </addData>
              </pou>
            </data>
            <data name="http://www.3s-software.com/plcopenxml/pou" handleUnknown="implementation">
              <pou name="OnOff_Control" pouType="functionBlock">
                <interface>
                  <inputVars>
                    <variable name="Feedback">
                      <type>
                        <REAL />
                      </type>
                    </variable>
                    <variable name="Setpoint">
